+            ok = value == check["equals"]
+            return ("held" if ok else "unmet",
+                    f"{check['field']} = {value!r} (want {check['equals']!r})")
+        if ctype == "gate_outcomes_pass":
+            fpath = os.path.join(base, check["file"])
+            if not os.path.exists(fpath):

+# commit-change stop condition — baked from reference/ice.md "### Done means" (#464/#465).
+# Evaluated by scripts/check_stop_condition.py at Step C0 of the Standard Play Close,
+# and between loop rounds. Paths are relative to the run's STM root ({stm_base}{issue}/).
+schema: { name: stop-condition }
+content:
+  done:
+    - id: D1
+      says: "the commit record exists"
+      check: { type: artifact_exists, path: "context/commits.yaml" }
+    - id: D2
+      says: "every change is committed or excluded with a recorded reason"
+      check: { type: field_equals, file: "context/commits.yaml", field: "leftover_count", equals: 0 }
+    - id: D3
+      says: "the working tree ended clean"
+      check: { type: field_equals, file: "context/commits.yaml", field: "tree_clean", equals: true }
+    - id: D4
+      says: "nothing was pushed"
+      check: { type: field_equals, file: "context/commits.yaml", field: "pushed", equals: false }
